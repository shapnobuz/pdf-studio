{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Studio",
  "version": "3.10.1",
  "identifier": "com.everflow.pdfstudio",
  "build": { "frontendDist": "../dist" },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "title": "PDF Studio", "width": 1200, "height": 800, "minWidth": 800, "minHeight": 500 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "fileAssociations": [
      { "ext": ["pdf"], "name": "PDF Document", "description": "PDF Document", "role": "Viewer" }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3MjIxNzBENEREMUM2MTAKUldRUXh0Rk5EUmNpbDBnaloxdnAyZU0xNzZvb2ZWSmllV2JWRHcxQ29PNmdQVGF1Vm9aODZFcUQK",
      "endpoints": [
        "https://github.com/shapnobuz/pdf-studio/releases/latest/download/latest.json"
      ]
    }
  }
}
